<!-- Modal del Consultor IA -->
<div id="consultor-modal" class="fixed inset-0 z-[100] hidden">
  <!-- Overlay -->
  <div id="consultor-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Panel -->
  <div class="absolute inset-4 md:inset-auto md:right-6 md:bottom-6 md:w-[440px] md:h-[580px] bg-white rounded-2xl shadow-2xl flex flex-col overflow-hidden z-10">
    <!-- Header -->
    <div class="bg-gradient-to-r from-brand-600 to-brand-500 text-white px-5 py-3.5 flex items-center justify-between flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-white/20 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-bold">Consultor IA — Newe Cloud</p>
          <p class="text-[10px] text-brand-200">Consulta gratuita personalizada</p>
        </div>
      </div>
      <button id="consultor-close" class="p-1 hover:bg-white/20 rounded-lg transition" aria-label="Cerrar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- Contenido dinámico -->
    <div id="consultor-body" class="flex-1 flex flex-col overflow-hidden">

      <!-- PASO 1: Email gate -->
      <div id="step-email" class="flex-1 flex flex-col items-center justify-center px-6 py-8 text-center">
        <div class="w-14 h-14 bg-brand-50 text-brand-500 rounded-2xl flex items-center justify-center mb-5">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-neutral-900">Tu consulta gratuita con IA</h3>
        <p class="mt-2 text-sm text-neutral-500 leading-relaxed max-w-xs">
          Describe tu reto de negocio y nuestro consultor IA te mostrará cómo podemos resolverlo con Salesforce e Inteligencia Artificial.
        </p>
        <p class="mt-1 text-xs text-neutral-400">
          Una consulta personalizada por empresa.
        </p>

        <div class="mt-6 w-full max-w-xs space-y-3">
          <input
            type="text"
            id="gate-name"
            placeholder="Tu nombre"
            class="w-full px-3.5 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all"
          />
          <input
            type="email"
            id="gate-email"
            placeholder="tu@empresa.com"
            class="w-full px-3.5 py-2.5 rounded-lg border border-neutral-200 bg-neutral-50 text-sm text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 transition-all"
          />
          <p id="gate-error" class="hidden text-xs text-red-500"></p>
          <button
            id="gate-submit"
            class="w-full bg-brand-500 hover:bg-brand-400 text-white text-sm font-semibold py-2.5 rounded-lg transition-all duration-300 shadow-md shadow-brand-500/20"
          >
            Iniciar consulta
          </button>
        </div>

        <p class="mt-4 text-[10px] text-neutral-400 max-w-xs">
          Tus datos solo se usan para personalizar la respuesta. No spam.
        </p>
      </div>

      <!-- PASO 2: Chat (una pregunta) -->
      <div id="step-chat" class="hidden flex-1 flex flex-col overflow-hidden">
        <!-- Chat area -->
        <div id="consultor-chat" class="flex-1 overflow-y-auto px-5 py-4 space-y-3">
          <!-- Mensaje de bienvenida (se inyecta dinámicamente) -->
        </div>

        <!-- Input area -->
        <div id="chat-input-area" class="border-t border-neutral-100 px-4 py-3 flex-shrink-0">
          <!-- Indicador de grabación -->
          <div id="recording-indicator" class="hidden items-center gap-2 mb-2 px-3 py-1.5 bg-red-50 rounded-lg">
            <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
            <span class="text-xs text-red-600 font-medium">Grabando...</span>
            <span id="recording-time" class="text-xs text-red-400 ml-auto">0:00</span>
          </div>

          <div class="flex items-end gap-2">
            <textarea
              id="consultor-input"
              rows="2"
              placeholder="Describe tu mayor reto de negocio..."
              class="flex-1 px-3 py-2.5 rounded-xl border border-neutral-200 bg-neutral-50 text-sm text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 resize-none transition-all"
              style="max-height: 80px;"
            ></textarea>

            <button
              id="consultor-mic"
              class="flex-shrink-0 w-10 h-10 bg-neutral-100 text-neutral-500 hover:bg-brand-50 hover:text-brand-500 rounded-xl flex items-center justify-center transition-all duration-300"
              aria-label="Grabar audio"
              title="Grabar audio"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"/>
              </svg>
            </button>

            <button
              id="consultor-send"
              class="flex-shrink-0 w-10 h-10 bg-brand-500 text-white hover:bg-brand-400 rounded-xl flex items-center justify-center transition-all duration-300 shadow-md shadow-brand-500/20 disabled:opacity-40 disabled:cursor-not-allowed"
              aria-label="Enviar"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- PASO 3: Resultado + CTA -->
      <div id="step-done" class="hidden flex-1 flex flex-col overflow-hidden">
        <div id="done-chat" class="flex-1 overflow-y-auto px-5 py-4 space-y-3"></div>

        <div class="border-t border-neutral-100 px-5 py-4 flex-shrink-0 bg-brand-50/50">
          <p class="text-xs text-neutral-500 text-center mb-3">
            Esto es solo una muestra. En una llamada de 20 minutos podemos profundizar en tu caso concreto.
          </p>
          <div class="flex flex-col gap-2">
            <a
              id="cta-whatsapp"
              href="#"
              target="_blank"
              rel="noopener"
              class="w-full bg-brand-500 hover:bg-brand-400 text-white text-sm font-semibold py-2.5 rounded-lg transition-all text-center flex items-center justify-center gap-2"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Agendar llamada por WhatsApp
            </a>
            <a
              id="cta-email"
              href="#"
              class="w-full border border-neutral-200 hover:bg-neutral-50 text-neutral-700 text-sm font-medium py-2.5 rounded-lg transition-all text-center"
            >
              Enviar email
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // --- DOM ---
  const modal = document.getElementById('consultor-modal')!;
  const overlay = document.getElementById('consultor-overlay')!;
  const closeBtn = document.getElementById('consultor-close')!;

  // Step 1: Email gate
  const stepEmail = document.getElementById('step-email')!;
  const gateName = document.getElementById('gate-name') as HTMLInputElement;
  const gateEmail = document.getElementById('gate-email') as HTMLInputElement;
  const gateError = document.getElementById('gate-error')!;
  const gateSubmit = document.getElementById('gate-submit')!;

  // Step 2: Chat
  const stepChat = document.getElementById('step-chat')!;
  const chat = document.getElementById('consultor-chat')!;
  const inputArea = document.getElementById('chat-input-area')!;
  const input = document.getElementById('consultor-input') as HTMLTextAreaElement;
  const sendBtn = document.getElementById('consultor-send')!;
  const micBtn = document.getElementById('consultor-mic')!;
  const recordingIndicator = document.getElementById('recording-indicator')!;
  const recordingTime = document.getElementById('recording-time')!;

  // Step 3: Done
  const stepDone = document.getElementById('step-done')!;
  const doneChat = document.getElementById('done-chat')!;

  let prospectName = '';
  let prospectEmail = '';
  let prospectQuery = '';
  let aiResponse = '';
  let isRecording = false;
  let recognition: any = null;
  let recordingTimer: number | null = null;
  let recordingSeconds = 0;

  // --- Modal open/close ---
  window.addEventListener('open-consultor', () => {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => gateName.focus(), 300);
  });

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    stopRecording();
  }
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  // --- Step 1: Email gate ---
  gateSubmit.addEventListener('click', () => {
    const name = gateName.value.trim();
    const email = gateEmail.value.trim();

    if (!name) {
      gateError.textContent = 'Por favor, introduce tu nombre.';
      gateError.classList.remove('hidden');
      gateName.focus();
      return;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      gateError.textContent = 'Por favor, introduce un email válido.';
      gateError.classList.remove('hidden');
      gateEmail.focus();
      return;
    }

    prospectName = name;
    prospectEmail = email;

    // Pasar a step 2
    stepEmail.classList.add('hidden');
    stepChat.classList.remove('hidden');
    stepChat.classList.add('flex');

    // Mensaje de bienvenida personalizado
    addBubble(chat, 'assistant', `¡Hola ${name}! Soy el consultor IA de Newe Cloud. Tienes una pregunta gratuita — hazla contar. **¿Cuál es el mayor reto de tu negocio ahora mismo?** Escríbelo o graba un audio.`);

    setTimeout(() => input.focus(), 200);
  });

  gateEmail.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') gateSubmit.click();
  });

  // --- Step 2: Chat (1 sola pregunta) ---
  async function sendMessage() {
    const text = input.value.trim();
    if (!text) return;

    prospectQuery = text;
    input.value = '';
    addBubble(chat, 'user', text);

    // Deshabilitar input inmediatamente
    input.disabled = true;
    sendBtn.setAttribute('disabled', '');
    micBtn.setAttribute('disabled', '');
    inputArea.style.opacity = '0.5';

    const typingId = addTyping(chat);

    try {
      const res = await fetch('/api/consultor', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: `Me llamo ${prospectName}. Mi consulta: ${text}`,
          email: prospectEmail,
          history: [],
        }),
      });

      const data = await res.json();
      removeTyping(typingId);

      if (data.error === 'limit_reached' || data.error === 'rate_limited') {
        addBubble(chat, 'assistant', data.message);
        addWhatsAppCTA(chat);
        return;
      } else if (data.error) {
        addBubble(chat, 'error', data.error);
        // Re-habilitar si hubo error técnico
        input.disabled = false;
        sendBtn.removeAttribute('disabled');
        micBtn.removeAttribute('disabled');
        inputArea.style.opacity = '1';
        return;
      } else {
        aiResponse = data.response;
        addBubble(chat, 'assistant', data.response);
      }

      // Transición a step 3 (done) después de un momento
      setTimeout(() => {
        // Copiar el chat al panel done
        doneChat.innerHTML = chat.innerHTML;
        stepChat.classList.add('hidden');
        stepChat.classList.remove('flex');
        stepDone.classList.remove('hidden');
        stepDone.classList.add('flex');
        doneChat.scrollTop = doneChat.scrollHeight;

        // Actualizar CTAs con contexto de la conversación
        updateCTAs();
      }, 2000);

    } catch {
      removeTyping(typingId);
      addBubble(chat, 'error', 'Error de conexión. Inténtalo de nuevo.');
      input.disabled = false;
      sendBtn.removeAttribute('disabled');
      micBtn.removeAttribute('disabled');
      inputArea.style.opacity = '1';
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // --- Audio: Web Speech API ---
  function setupSpeech() {
    const SR = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SR) return null;
    const rec = new SR();
    rec.lang = 'es-ES';
    rec.continuous = true;
    rec.interimResults = true;
    let finalText = '';

    rec.onresult = (event: any) => {
      let interim = '';
      for (let i = event.resultIndex; i < event.results.length; i++) {
        if (event.results[i].isFinal) {
          finalText += event.results[i][0].transcript + ' ';
        } else {
          interim += event.results[i][0].transcript;
        }
      }
      input.value = finalText + interim;
    };

    rec.onend = () => {
      if (finalText.trim()) input.value = finalText.trim();
      finalText = '';
      stopRecordingUI();
    };
    rec.onerror = () => stopRecordingUI();
    return rec;
  }

  function startRecording() {
    recognition = setupSpeech();
    if (!recognition) {
      addBubble(chat, 'error', 'Tu navegador no soporta grabación de audio. Usa Chrome o Edge.');
      return;
    }
    recognition.start();
    isRecording = true;
    recordingSeconds = 0;
    recordingIndicator.classList.remove('hidden');
    recordingIndicator.classList.add('flex');
    micBtn.classList.add('bg-red-100', 'text-red-500');
    micBtn.classList.remove('bg-neutral-100', 'text-neutral-500');
    recordingTimer = window.setInterval(() => {
      recordingSeconds++;
      const m = Math.floor(recordingSeconds / 60);
      const s = recordingSeconds % 60;
      recordingTime.textContent = `${m}:${String(s).padStart(2, '0')}`;
    }, 1000);
  }

  function stopRecording() {
    if (recognition) { recognition.stop(); recognition = null; }
    stopRecordingUI();
  }

  function stopRecordingUI() {
    isRecording = false;
    recordingIndicator.classList.add('hidden');
    recordingIndicator.classList.remove('flex');
    micBtn.classList.remove('bg-red-100', 'text-red-500');
    micBtn.classList.add('bg-neutral-100', 'text-neutral-500');
    if (recordingTimer) { clearInterval(recordingTimer); recordingTimer = null; }
  }

  micBtn.addEventListener('click', () => {
    if (isRecording) stopRecording();
    else startRecording();
  });

  // --- Helpers de UI ---
  function addBubble(container: HTMLElement, role: 'user' | 'assistant' | 'error', content: string) {
    const div = document.createElement('div');
    if (role === 'user') {
      div.className = 'flex justify-end';
      div.innerHTML = `<div class="bg-brand-500 text-white rounded-xl rounded-tr-none px-4 py-2.5 max-w-[85%]"><p class="text-sm leading-relaxed">${esc(content)}</p></div>`;
    } else if (role === 'assistant') {
      div.className = 'flex gap-2.5';
      div.innerHTML = `
        <div class="flex-shrink-0 w-7 h-7 bg-brand-100 text-brand-600 rounded-lg flex items-center justify-center mt-0.5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
        </div>
        <div class="bg-neutral-50 rounded-xl rounded-tl-none px-4 py-2.5 max-w-[85%]">
          <div class="text-sm text-neutral-700 leading-relaxed">${fmt(content)}</div>
        </div>`;
    } else {
      div.className = 'flex justify-center';
      div.innerHTML = `<div class="bg-red-50 text-red-600 text-xs rounded-lg px-3 py-2">${esc(content)}</div>`;
    }
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
  }

  function addTyping(container: HTMLElement): string {
    const id = 'typing-' + Date.now();
    const div = document.createElement('div');
    div.id = id;
    div.className = 'flex gap-2.5';
    div.innerHTML = `
      <div class="flex-shrink-0 w-7 h-7 bg-brand-100 text-brand-600 rounded-lg flex items-center justify-center">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
      </div>
      <div class="bg-neutral-50 rounded-xl rounded-tl-none px-4 py-3">
        <div class="flex gap-1.5">
          <span class="w-1.5 h-1.5 bg-neutral-300 rounded-full animate-bounce" style="animation-delay:0ms"></span>
          <span class="w-1.5 h-1.5 bg-neutral-300 rounded-full animate-bounce" style="animation-delay:150ms"></span>
          <span class="w-1.5 h-1.5 bg-neutral-300 rounded-full animate-bounce" style="animation-delay:300ms"></span>
        </div>
      </div>`;
    container.appendChild(div);
    container.scrollTop = container.scrollHeight;
    return id;
  }

  function removeTyping(id: string) { document.getElementById(id)?.remove(); }

  function esc(t: string): string {
    const d = document.createElement('div');
    d.textContent = t;
    return d.innerHTML;
  }

  function fmt(t: string): string {
    return t
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/\n\n/g, '</p><p class="mt-2">')
      .replace(/\n- /g, '</p><li class="ml-4 list-disc text-sm text-neutral-700">')
      .replace(/\n(\d+)\. /g, '</p><li class="ml-4 list-decimal text-sm text-neutral-700">')
      .replace(/^/, '<p>').replace(/$/, '</p>');
  }

  function addWhatsAppCTA(container: HTMLElement) {
    const div = document.createElement('div');
    div.className = 'flex justify-center mt-2';
    div.innerHTML = `
      <a href="https://wa.me/34664320346?text=${encodeURIComponent(`Hola, soy ${prospectName || 'un visitante de la web'}. Me gustaría agendar una llamada para explorar cómo Salesforce + IA puede ayudar a mi negocio.`)}"
         target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-all shadow-md">
