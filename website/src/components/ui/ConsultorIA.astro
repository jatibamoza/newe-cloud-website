  function stripMarkdown(t: string): string {
    return t.replace(/\*\*(.*?)\*\*/g, '$1').replace(/\*(.*?)\*/g, '$1');
  }

  function truncate(t: string, max: number): string {
    if (t.length <= max) return t;
    return t.substring(0, max) + '...';
  }

  function updateCTAs() {
    const ctaWa = document.getElementById('cta-whatsapp') as HTMLAnchorElement;
    const ctaEmail = document.getElementById('cta-email') as HTMLAnchorElement;

    const cleanResponse = stripMarkdown(aiResponse);

    // WhatsApp: mensaje con contexto ordenado
    const waText = [
      `Hola, soy ${prospectName}.`,
      ``,
      `Acabo de usar el consultor IA de Newe Cloud y me gustaría agendar una llamada para profundizar.`,
      ``,
      `--- Mi consulta ---`,
      prospectQuery,
      ``,
      `--- Recomendación del consultor IA ---`,
      truncate(cleanResponse, 800),
      ``,
      `¿Podemos agendar una llamada de 20 minutos?`,
    ].join('\n');

    ctaWa.href = `https://wa.me/34664320346?text=${encodeURIComponent(waText)}`;

    // Email: subject descriptivo + body con contexto
    const emailSubject = `Consulta IA - ${prospectName} - ${truncate(prospectQuery, 60)}`;
    const emailBody = [
      `Hola equipo de Newe Cloud,`,
      ``,
      `Soy ${prospectName} (${prospectEmail}).`,
      `Acabo de usar el consultor IA en su web y me gustaría profundizar en mi caso.`,
      ``,
      `MI CONSULTA:`,
      prospectQuery,
      ``,
      `RECOMENDACIÓN DEL CONSULTOR IA:`,
      cleanResponse,
      ``,
      `Me gustaría agendar una llamada para explorar esto más a fondo.`,
      ``,
      `Gracias.`,
    ].join('\n');

    ctaEmail.href = `mailto:comercial@newecloud.io?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`;
  }
</script>
