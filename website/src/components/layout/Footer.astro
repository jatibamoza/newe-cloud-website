---
const year = new Date().getFullYear();
---

<footer class="bg-neutral-900 text-neutral-400 py-10">
  <div class="max-w-5xl mx-auto px-4 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Marca -->
      <div>
        <img
          src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=160,fit=crop,q=95/YZ9jEpZkE9SzrQQZ/copia-de-newe-logo-1-m5KnNZMoywUEZBE2.png"
          alt="Newe Cloud"
          class="h-8 brightness-200"
          loading="lazy"
        />
        <p class="mt-2 text-xs leading-relaxed">
          Consultoría Salesforce e IA para PYMEs.<br />
          Tu experto, a una llamada de distancia.
        </p>
      </div>

      <!-- Enlaces -->
      <div>
        <h4 class="font-semibold text-white text-xs uppercase tracking-wider mb-3">Navegación</h4>
        <ul class="space-y-1.5 text-xs">
          <li><a href="/#pilares" class="hover:text-brand-400 transition-colors">Descubre Newe</a></li>
          <li><a href="/#servicios" class="hover:text-brand-400 transition-colors">Servicios</a></li>
          <li><a href="/#nosotros" class="hover:text-brand-400 transition-colors">Sobre Nosotros</a></li>
          <li><a href="/blog" class="hover:text-brand-400 transition-colors">Blog</a></li>
          <li><a href="/#contacto" class="hover:text-brand-400 transition-colors">Contacto</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="font-semibold text-white text-xs uppercase tracking-wider mb-3">Contacto</h4>
        <ul class="space-y-1.5 text-xs">
          <li>
            <a href="mailto:comercial@newecloud.io" class="hover:text-brand-400 transition-colors">
              comercial@newecloud.io
            </a>
          </li>
          <li>
            <a href="tel:+34664320346" class="hover:text-brand-400 transition-colors">
              +34 6643 20 346
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/company/newe-cloud"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 hover:text-brand-400 transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-neutral-800 text-center text-xs text-neutral-500">
      &copy; {year} Newe Cloud. Todos los derechos reservados.
    </div>
  </div>
</footer>
