---
const pilares = [
  {
    titulo: 'New-e-ficiencia',
    descripcion: 'Modelos más coste-efectivos que la consultoría tradicional. Pagas solo por el talento y el tiempo que consumes.',
    imagen: 'https://images.unsplash.com/photo-1553877522-43269d4ea984?auto=format&fit=crop&w=400&h=400&q=80',
    alt: 'Eficiencia en consultoría',
    delay: 'delay-100',
  },
  {
    titulo: 'New-e-xperiencia',
    descripcion: 'Trato directo, cercano y personalizado. Un único interlocutor senior que construye relaciones de confianza.',
    imagen: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=400&h=400&q=80',
    alt: 'Experiencia personalizada',
    delay: 'delay-200',
  },
  {
    titulo: 'New-e-scalabilidad',
    descripcion: 'Capaz de asumir proyectos de cualquier tamaño y adaptarse a necesidades cambiantes. Crecemos contigo.',
    imagen: 'https://images.unsplash.com/photo-1588610991095-734b1574b960?auto=format&fit=crop&w=400&h=400&q=80',
    alt: 'Escalabilidad',
    delay: 'delay-300',
  },
];
---

<section id="pilares" class="py-14 md:py-20 bg-white relative overflow-hidden">
  <div class="absolute top-20 right-[-200px] w-[500px] h-[500px] bg-brand-100 blob opacity-40"></div>

  <div class="relative max-w-5xl mx-auto px-4 md:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <span class="text-brand-500 font-semibold text-xs uppercase tracking-[0.15em]">Nuestros pilares</span>
      <h2 class="mt-2 text-2xl md:text-3xl font-extrabold text-neutral-900 tracking-tight">
        ¿Por qué Newe Cloud?
      </h2>
      <p class="mt-2 text-neutral-500 max-w-xl mx-auto text-sm leading-relaxed">
        Hemos redefinido el modelo de consultoría Salesforce tradicional.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {pilares.map(pilar => (
        <div class={`animate-on-scroll ${pilar.delay} flex flex-col items-center text-center group`}>
          <div class="relative w-32 h-32 mb-5">
            <div class="absolute inset-0 rounded-full border-2 border-dashed border-brand-200 group-hover:border-brand-400 group-hover:rotate-180 transition-all duration-1000"></div>
            <div class="absolute inset-2 rounded-full overflow-hidden shadow-lg ring-3 ring-white">
              <img
                src={pilar.imagen}
                alt={pilar.alt}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="text-base font-bold text-neutral-900 group-hover:text-brand-600 transition-colors duration-300">{pilar.titulo}</h3>
          <p class="mt-2 text-neutral-500 text-sm leading-relaxed max-w-xs">{pilar.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>
