---
const casos = [
  {
    etiqueta: 'Ventas',
    titulo: '¿Y si tu CRM te dijera a quién llamar hoy?',
    problema: 'Tu equipo pierde horas revisando leads manualmente sin saber cuáles tienen más potencial.',
    solucion: 'Una IA integrada en Salesforce analiza el comportamiento de cada lead — emails abiertos, páginas visitadas, interacciones previas — y cada mañana le dice a tu equipo: "Estas son las 5 oportunidades que debes trabajar hoy, y por qué."',
    impacto: '+35% tasa de conversión',
    impactoDetalle: 'Priorización inteligente de pipeline',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941"/></svg>`,
  },
  {
    etiqueta: 'Atención al cliente',
    titulo: 'Un agente que resuelve tickets mientras tu equipo duerme',
    problema: 'Tus clientes esperan horas por respuestas a preguntas que ya están en tu base de conocimiento.',
    solucion: 'Un agente de IA conectado a Service Cloud responde automáticamente el 70% de las consultas frecuentes — devoluciones, estado de pedidos, dudas técnicas — con el tono de tu marca y escalando solo lo complejo a tu equipo.',
    impacto: '70% tickets resueltos sin humano',
    impactoDetalle: 'Atención 24/7 desde el día uno',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155"/></svg>`,
  },
  {
    etiqueta: 'Productividad',
    titulo: 'Pregúntale a tu Salesforce como si fuera una persona',
    problema: 'Crear reportes en Salesforce requiere conocimiento técnico. Tu equipo depende de alguien que sepa SOQL o que arme los dashboards.',
    solucion: 'Escribes "¿Cuántos leads del sector retail cerramos en Q1?" y la IA te devuelve el dato, el gráfico y el análisis — sin tocar un filtro. Tu Salesforce se convierte en un asistente que habla tu idioma.',
    impacto: '15 horas/semana ahorradas',
    impactoDetalle: 'Reportes en lenguaje natural',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>`,
  },
  {
    etiqueta: 'Retención',
    titulo: 'Detectar que un cliente se va antes de que él lo sepa',
    problema: 'Cuando un cliente cancela, ya es tarde. No tienes forma de anticiparte.',
    solucion: 'La IA analiza patrones de uso, frecuencia de contacto, tickets abiertos y actividad en tu CRM. Cuando detecta señales de riesgo, crea automáticamente una tarea para que tu equipo actúe — una llamada, una oferta, una solución — antes de que sea tarde.',
    impacto: '-40% tasa de abandono',
    impactoDetalle: 'Alertas proactivas de churn',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>`,
  },
  {
    etiqueta: 'Operaciones',
    titulo: 'Que la IA haga el data entry por ti',
    problema: 'Tu equipo pasa horas metiendo datos en Salesforce después de cada reunión, llamada o email.',
    solucion: 'La IA escucha tus llamadas, lee tus correos y extrae automáticamente los datos relevantes: contactos nuevos, notas de reunión, próximos pasos, montos de oportunidad. Todo queda registrado en Salesforce sin que nadie toque un formulario.',
    impacto: '10+ horas/semana liberadas',
    impactoDetalle: 'Auto-captura desde email y llamadas',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776"/></svg>`,
  },
  {
    etiqueta: 'Crecimiento',
    titulo: 'Propuestas comerciales en 2 minutos, no en 2 días',
    problema: 'Cada propuesta comercial requiere horas de trabajo manual: buscar datos del cliente, armar el documento, personalizar.',
    solucion: 'La IA accede al historial del cliente en Salesforce, entiende su industria, sus compras anteriores y sus necesidades, y genera una propuesta personalizada lista para enviar. Tu equipo solo revisa y envía.',
    impacto: '3x más propuestas enviadas',
    impactoDetalle: 'Generación automática de documentos',
    icono: `<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
  },
];
---

<section id="casos-de-uso" class="py-14 md:py-20 bg-gradient-to-b from-brand-950 to-neutral-900 text-white relative overflow-hidden">
  <!-- Decoración de fondo -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
  <div class="absolute top-[-150px] right-[-100px] w-[400px] h-[400px] bg-brand-500 blob opacity-10 animate-float-slow"></div>
  <div class="absolute bottom-[-100px] left-[-80px] w-[300px] h-[300px] bg-brand-400 blob opacity-10 animate-float" style="animation-delay: -4s;"></div>

  <div class="relative max-w-5xl mx-auto px-4 md:px-8">
    <!-- Header -->
    <div class="text-center mb-12 animate-on-scroll">
      <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 rounded-full px-3 py-1.5 mb-4">
        <svg class="w-3.5 h-3.5 text-accent-yellow" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
        </svg>
        <span class="text-xs font-medium text-neutral-300">Salesforce + IA en acción</span>
      </span>
      <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight">
        Lo que podemos construir
        <span class="bg-gradient-to-r from-brand-300 to-accent-yellow bg-clip-text text-transparent"> juntos</span>
      </h2>
      <p class="mt-3 text-neutral-400 max-w-xl mx-auto text-sm leading-relaxed">
        No hablamos de futuro. Estas son soluciones que implementamos hoy
        combinando Salesforce con inteligencia artificial.
      </p>
    </div>

    <!-- Casos -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {casos.map((caso, i) => (
        <div class={`animate-on-scroll delay-${((i % 4) + 1) * 100} group relative bg-white/[0.04] backdrop-blur-sm border border-white/[0.08] rounded-xl p-6 hover:bg-white/[0.08] hover:border-brand-400/30 transition-all duration-500`}>
          <!-- Glow on hover -->
          <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-brand-500/0 to-brand-400/0 group-hover:from-brand-500/5 group-hover:to-brand-400/5 transition-all duration-500"></div>

          <div class="relative">
            <!-- Header del caso -->
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 bg-brand-500/20 text-brand-300 rounded-lg flex items-center justify-center group-hover:bg-brand-500 group-hover:text-white transition-all duration-300">
                <Fragment set:html={caso.icono} />
              </div>
              <span class="text-[10px] font-semibold uppercase tracking-wider text-brand-400">{caso.etiqueta}</span>
            </div>

            <!-- Título provocativo -->
            <h3 class="text-base font-bold text-white group-hover:text-brand-200 transition-colors duration-300 leading-snug">
              {caso.titulo}
            </h3>

            <!-- Problema -->
            <p class="mt-2 text-xs text-neutral-500 leading-relaxed">
              <span class="text-accent-pink font-semibold">El problema:</span> {caso.problema}
            </p>

            <!-- Solución -->
            <p class="mt-2 text-xs text-neutral-300 leading-relaxed">
              <span class="text-accent-green font-semibold">La solución:</span> {caso.solucion}
            </p>

            <!-- Impacto -->
            <div class="mt-4 flex items-center gap-3 pt-3 border-t border-white/[0.06]">
              <span class="text-lg font-extrabold bg-gradient-to-r from-accent-green to-brand-300 bg-clip-text text-transparent">
                {caso.impacto}
              </span>
              <span class="text-[10px] text-neutral-500">{caso.impactoDetalle}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 text-center animate-on-scroll">
      <p class="text-sm text-neutral-400 mb-4">
        Cada negocio es diferente. Habla con nuestro consultor IA y descubre qué podemos hacer por ti.
      </p>
      <button
        id="open-consultor-btn"
        class="group inline-flex items-center gap-2 bg-white text-brand-600 text-sm font-bold px-6 py-3 rounded-full hover:bg-brand-100 transition-all duration-300 shadow-xl shadow-black/20 hover:-translate-y-0.5 cursor-pointer"
      >
        <svg class="w-4 h-4 text-brand-500 animate-pulse-soft" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
        </svg>
        Quiero ver qué es posible para mi empresa
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </button>
    </div>

    <script>
      document.getElementById('open-consultor-btn')?.addEventListener('click', () => {
        window.dispatchEvent(new Event('open-consultor'));
      });
    </script>
  </div>
</section>
