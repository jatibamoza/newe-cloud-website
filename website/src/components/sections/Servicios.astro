---
const servicios = [
  {
    titulo: 'Admin as a Service',
    descripcion: 'Paquetes de horas mensuales para mantenimiento, soporte continuo y mejoras evolutivas de tu Salesforce.',
    beneficio: 'Proactividad, tranquilidad y mantenimiento preventivo.',
    icono: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    delay: 'delay-100',
  },
  {
    titulo: 'Consultoría Bajo Demanda',
    descripcion: 'Consultores por horas o días para tareas específicas: desarrollo Apex/LWC, integraciones, auditorías.',
    beneficio: 'Agilidad, pago por uso, precisión técnica.',
    icono: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>`,
    delay: 'delay-200',
  },
  {
    titulo: 'Bolsas de Horas',
    descripcion: 'Bloques de horas consumibles a tu ritmo durante 3, 6 o 12 meses. Flexibilidad total.',
    beneficio: 'Sin sorpresas de coste, acceso prioritario.',
    icono: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    delay: 'delay-300',
  },
  {
    titulo: 'Inteligencia Artificial + CRM',
    descripcion: 'Integración de IA en tu Salesforce: Agentforce, Einstein AI, chatbots inteligentes, automatización con LLMs.',
    beneficio: 'Potencia tu CRM con inteligencia artificial.',
    icono: `<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>`,
    delay: 'delay-400',
  },
];
---

<section id="servicios" class="py-14 md:py-20 bg-neutral-50 relative overflow-hidden">
  <div class="absolute bottom-0 left-[-100px] w-[400px] h-[400px] bg-brand-100 blob opacity-30"></div>

  <div class="relative max-w-5xl mx-auto px-4 md:px-8">
    <div class="text-center mb-10 animate-on-scroll">
      <span class="text-brand-500 font-semibold text-xs uppercase tracking-[0.15em]">Soluciones</span>
      <h2 class="mt-2 text-2xl md:text-3xl font-extrabold text-neutral-900 tracking-tight">
        Nuestros Servicios
      </h2>
      <p class="mt-2 text-neutral-500 max-w-xl mx-auto text-sm leading-relaxed">
        Modelos de contratación flexibles diseñados para PYMEs que necesitan
        resultados reales sin compromisos rígidos.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {servicios.map(servicio => (
        <div class={`animate-on-scroll ${servicio.delay} hover-lift group bg-white p-6 rounded-xl border border-neutral-100 cursor-default`}>
          <div class="w-11 h-11 bg-brand-50 text-brand-500 rounded-xl flex items-center justify-center group-hover:bg-brand-500 group-hover:text-white group-hover:rotate-6 transition-all duration-400">
            <Fragment set:html={servicio.icono} />
          </div>
          <h3 class="mt-3 text-base font-bold text-neutral-900 group-hover:text-brand-600 transition-colors duration-300">
            {servicio.titulo}
          </h3>
          <p class="mt-2 text-neutral-500 text-sm leading-relaxed">{servicio.descripcion}</p>
          <div class="mt-3 flex items-center gap-2 text-xs font-semibold text-brand-500 group-hover:gap-3 transition-all duration-300">
            <span>{servicio.beneficio}</span>
            <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all duration-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center animate-on-scroll">
      <a
        href="#contacto"
        class="group inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-400 text-white text-sm font-semibold px-6 py-3 rounded-full transition-all duration-300 shadow-xl shadow-brand-500/25 hover:shadow-brand-400/40 hover:-translate-y-0.5"
      >
        Solicitar información
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
